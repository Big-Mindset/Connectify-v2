// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id
  name          String
  email         String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  username      String
  lastseen      DateTime @default(now())

  notifications   Notification[]
  status          Status[]
  reactions       reactionUsers[]
  sessions        Session[]
  accounts        Account[]
  friendship1     Friendship[]      @relation("friendship1")
  friendship2     Friendship[]      @relation("friendship2")
  blocker         Block[]           @relation("blocker")
  blocked         Block[]           @relation("blocked")
  sender          Request[]         @relation(name: "senderId")
  receiver        Request[]         @relation(name: "receiverId")
  messageSender   Message[]
  chatParticipant ChatParticipant[]

  bio String?

  @@unique([email])
  @@unique([username])
  @@index([username])
  @@map("user")
}

model Block {
  id        String   @id @default(uuid())
  blockedId String
  blockerId String
  blocker   User     @relation("blocker", references: [id], fields: [blockerId])
  blocked   User     @relation("blocked", references: [id], fields: [blockedId])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([blockerId, blockedId])
  @@index([blockerId, createdAt])
}

model Friendship {
  id      String @id @default(uuid())
  user1Id String
  user2Id String

  user1     User     @relation("friendship1", references: [id], fields: [user1Id], onDelete: Cascade)
  user2     User     @relation("friendship2", references: [id], fields: [user2Id], onDelete: Cascade)
  chat      Chat?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([user1Id, user2Id])
  @@index([user1Id, createdAt(sort: Desc)])
  @@index([user2Id, createdAt(sort: Desc)])
  @@map("friendship")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Request {
  id         String        @id @default(uuid())
  sender     User          @relation(references: [id], fields: [senderId], name: "senderId", onDelete: Cascade)
  senderId   String
  receiver   User          @relation(references: [id], fields: [receiverId], name: "receiverId", onDelete: Cascade)
  receiverId String
  status     RequestStatus @default(Pending)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([senderId, receiverId])
  @@index([senderId, status])
  @@index([receiverId, status])
  @@map("request")
}

enum RequestStatus {
  Pending
  Accepted
  Rejected
}

model Chat {
  id                        String            @id @default(uuid())
  lastMessageId             String?
  name                      String?
  description               String?
  image                     Media?            @relation(name: "group-pfp")
  isGroup                   Boolean           @default(false)
  media                     Media[]           @relation(name: "message-media")
  disappearMessagesDuration DateTime?
  participants              ChatParticipant[]
  messages                  Message[]
  lastMessage               Message?          @relation(fields: [lastMessageId], references: [id], name: "lastMessage", onDelete: SetNull)
  friendshipId              String            @unique
  FriendShip                Friendship        @relation(fields: [friendshipId], references: [id])
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  pinnedAt                  DateTime?

  @@unique([lastMessageId])
  @@index([lastMessageId])
  @@index([pinnedAt, createdAt(sort: Desc)])
  @@index([friendshipId])
}

enum Roles {
  ADMIN
  MEMBER
  OWNER
}

model ChatParticipant {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatId      String
  chat        Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  muted       Boolean   @default(false)
  mutedTil    DateTime?
  role        Roles?
  clearChatAt DateTime?

  @@unique([userId, chatId])
  @@index([clearChatAt])
  @@index([chatId, userId])
  @@index([userId])
  @@map("chat_participant")
}

model Message {
  id                 String                @id @default(uuid())
  senderId           String
  chatId             String
  lastMessage        Chat?                 @relation("lastMessage")
  encryptedContent   String?
  search_index       String[]
  reactions          reaction[]
  replyToId          String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  forwarded          Boolean               @default(false)
  expiredAt          DateTime?
  replyTo            Message?              @relation(references: [id], fields: [replyToId], name: "replyToMessage", onDelete: SetNull)
  sender             User                  @relation(references: [id], fields: [senderId])
  chat               Chat                  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  replies            Message[]             @relation("replyToMessage")
  media              Media[]
  message_security   message_securityKeys?
  status             Status[]

  @@index([chatId, senderId, createdAt])
  @@index([senderId])
  @@index([createdAt])
  @@index([search_index], type: Gin)
}

model reaction {
  id        String  @id @default(uuid())
  emoji String
  name String?
  reactors reactionUsers[]
  messageId String
  message   Message @relation(fields: [messageId], references: [id] , onDelete: Cascade)
  @@unique([emoji,messageId])
}
model reactionUsers {
  id String @id @default(uuid())
  reactionId String
  reaction reaction @relation(fields: [reactionId],references: [id] , onDelete: Cascade)
  userId String
  user User @relation(fields: [userId],references: [id])
  @@unique([reactionId,userId])
}

model message_securityKeys {
  id           String   @id @default(uuid())
  vi_v1        String
  authTag_v1   String
  vi_v2        String
  authTag_v2   String
  encryptedDek String
  messageId    String   @unique
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

model Status {
  id          String    @id @default(uuid())
  readAt      DateTime?
  deliveredAt DateTime?
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  status      status    @default(PENDING)
  messageId   String    @unique
  message     Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([readAt])
  @@index([deliveredAt])
}

enum status {
  SENT
  DELIVERED
  READ
  PENDING
}

model Media {
  id              String   @id @default(uuid())
  url String
  publicId String
  filename String?
  size Int?
  type            String
  messageId       String?
  chatPfpId       String?  @unique
  chatPfp         Chat?    @relation(name: "group-pfp", fields: [chatPfpId], references: [id])
  chatId          String?
  chat            Chat?    @relation(name: "message-media", fields: [chatId], references: [id])
  message         Message? @relation(references: [id], fields: [messageId], onDelete: Cascade)
  groupMessageId  String?
  createdAt       DateTime @default(now())

  @@index([messageId])
  @@index([chatId])
}

// TODO -  DO THESE OPERATIONS LATER

model Notification {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  content   String
  type      noficationType
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

}

enum noficationType {
  FRIEND_REQUEST
  Message
  INVITE
  Accepted
}

